{% extends '@EasyAdmin/page/content.html.twig' %}

{% block page_title %}公司项目总览{% endblock %}

{% block head_stylesheets %}
    {{ parent() }}
    <style>
        .org-tree {
            list-style: none;
            padding-left: 0;
            margin-bottom: 0;
        }
        .org-tree .org-tree {
            padding-left: 1.5rem;
            margin-top: 0.25rem;
            border-left: 2px solid #dee2e6;
        }
        .org-tree-item {
            margin-bottom: 0.25rem;
        }
        .org-tree-link {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 1rem;
            padding: 0.75rem 1rem;
            border: 1px solid #dee2e6;
            border-radius: 0.375rem;
            background: #fff;
            color: inherit;
            text-decoration: none;
            transition: background 0.15s, box-shadow 0.15s;
        }
        .org-tree-link:hover {
            background: #f8f9fa;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
            color: inherit;
        }
        .org-tree-name {
            font-weight: 600;
        }
        .org-tree-meta {
            color: #6c757d;
            font-size: 0.875rem;
        }
        .org-tree-badges {
            display: flex;
            flex-wrap: wrap;
            gap: 0.5rem;
            flex-shrink: 0;
        }
    </style>
{% endblock %}

{% block main %}
<div class="container-fluid">
    {% if tree is empty %}
        <div class="alert alert-info mb-0">
            <i class="fas fa-info-circle"></i> 暂无可查看的组织机构
        </div>
    {% else %}
        <ul class="org-tree">
            {% for node in tree %}
                {{ _self.render_org_node(node) }}
            {% endfor %}
        </ul>
    {% endif %}
</div>
{% endblock %}

{% macro render_org_node(node) %}
    <li class="org-tree-item">
        <a href="{{ node.projectListUrl }}" class="org-tree-link">
            <div>
                <div class="org-tree-name">{{ node.name }}</div>
                <div class="org-tree-meta">
                    <span>{{ node.orgCode }}</span>
                    {% if node.contactPerson %}
                        <span class="ms-2"><i class="fas fa-user"></i> {{ node.contactPerson }}</span>
                    {% endif %}
                </div>
            </div>
            <div class="org-tree-badges">
                <span class="badge bg-primary-subtle" title="直属项目数">
                    直属 {{ node.directProjectCount }}
                </span>
                <span class="badge bg-secondary-subtle" title="含下级组织项目总数">
                    合计 {{ node.totalProjectCount }}
                </span>
            </div>
        </a>
        {% if node.children is not empty %}
            <ul class="org-tree">
                {% for child in node.children %}
                    {{ _self.render_org_node(child) }}
                {% endfor %}
            </ul>
        {% endif %}
    </li>
{% endmacro %}
