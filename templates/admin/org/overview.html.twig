{% extends '@EasyAdmin/page/content.html.twig' %}

{% block page_title %}公司项目总览{% endblock %}

{% block head_stylesheets %}
{{ parent() }}
<style>
.org-tree-root {
    list-style: none;
    padding: 0;
    margin: 0;
}

.org-children {
    list-style: none;
    padding: 0;
    margin: 0 0 0 1.5rem;
    border-left: 2px solid var(--bs-border-color, #dee2e6);
}

.org-node {
    margin: 0;
    padding: 0;
}

details.org-details > summary {
    list-style: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.45rem 0.6rem;
    border-radius: 0.375rem;
    user-select: none;
    transition: background 0.1s ease;
}

details.org-details > summary::-webkit-details-marker {
    display: none;
}

details.org-details > summary::before {
    content: '▶';
    font-size: 0.6rem;
    color: var(--bs-secondary-color, #6c757d);
    flex-shrink: 0;
    transition: transform 0.15s ease;
    width: 0.8rem;
    display: inline-block;
}

details.org-details[open] > summary::before {
    transform: rotate(90deg);
}

details.org-details.org-leaf > summary::before {
    visibility: hidden;
}

details.org-details > summary:hover {
    background: var(--bs-tertiary-bg, #f8f9fa);
}

.org-name {
    font-weight: 500;
    font-size: 0.9rem;
}

.org-abbr {
    font-size: 0.7rem;
    padding: 0.1rem 0.4rem;
    border-radius: 0.25rem;
    background: var(--bs-secondary-bg, #e9ecef);
    color: var(--bs-secondary-color, #6c757d);
    font-family: monospace;
    letter-spacing: 0.02em;
}

.org-count-link {
    text-decoration: none;
    font-size: 0.78rem;
    padding: 0.15rem 0.45rem;
    border-radius: 999px;
    background: var(--bs-primary-bg-subtle, #cfe2ff);
    color: var(--bs-primary-text-emphasis, #0a58ca);
    transition: background 0.1s ease;
    white-space: nowrap;
}

.org-count-link:hover {
    background: var(--bs-primary, #0d6efd);
    color: #fff;
}

.org-count-link.zero {
    background: var(--bs-secondary-bg, #e9ecef);
    color: var(--bs-secondary-color, #6c757d);
}

.org-total-badge {
    font-size: 0.72rem;
    color: var(--bs-secondary-color, #6c757d);
    white-space: nowrap;
}

details.org-project-details {
    margin: 0.15rem 0 0.25rem 1.3rem;
}

details.org-project-details > summary {
    list-style: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.3rem 0.5rem;
    font-size: 0.78rem;
    color: var(--bs-secondary-color, #6c757d);
    border-radius: 0.25rem;
    user-select: none;
}

details.org-project-details > summary::-webkit-details-marker {
    display: none;
}

details.org-project-details > summary::before {
    content: '▶';
    font-size: 0.55rem;
    flex-shrink: 0;
    transition: transform 0.15s ease;
    width: 0.7rem;
    display: inline-block;
}

details.org-project-details[open] > summary::before {
    transform: rotate(90deg);
}

details.org-project-details > summary:hover {
    background: var(--bs-tertiary-bg, #f8f9fa);
    color: var(--bs-body-color, #212529);
}

.org-project-list {
    list-style: none;
    padding: 0.25rem 0 0.25rem 0.5rem;
    margin: 0;
}

.org-project-row {
    margin-bottom: 0.2rem;
}

.org-project-row:last-child {
    margin-bottom: 0;
}

.org-project-row a {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    padding: 0.35rem 0.5rem;
    border-radius: 0.25rem;
    font-size: 0.8125rem;
    color: inherit;
    text-decoration: none;
    transition: background 0.1s ease;
}

.org-project-row a:hover {
    background: var(--bs-tertiary-bg, #f8f9fa);
}

.org-project-row-name {
    font-weight: 500;
}

.org-project-row-meta {
    font-size: 0.75rem;
    color: var(--bs-secondary-color, #6c757d);
}

.org-tree-toolbar {
    display: flex;
    justify-content: flex-end;
    margin-bottom: 0.75rem;
}
</style>
{% endblock %}

{% block body_javascript %}
    {{ parent() }}
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const btn = document.getElementById('toggle-all-projects');
            if (!btn) {
                return;
            }

            const getProjectDetails = () => document.querySelectorAll('details.org-project-details');

            const syncButton = () => {
                const details = getProjectDetails();
                const allOpen = details.length > 0 && Array.from(details).every((el) => el.open);
                btn.textContent = allOpen ? '收起全部项目' : '展开全部项目';
            };

            btn.addEventListener('click', function () {
                const details = getProjectDetails();
                const shouldExpand = Array.from(details).some((el) => !el.open);
                details.forEach((el) => { el.open = shouldExpand; });
                syncButton();
            });

            document.querySelectorAll('details.org-project-details').forEach((el) => {
                el.addEventListener('toggle', syncButton);
            });

            syncButton();
        });
    </script>
{% endblock %}

{% macro render_node(node) %}
    {% set hasChildren = node.children is not empty %}
    {% set hasProjects = node.projects is not empty %}
    <li class="org-node">
        <details class="org-details{{ not hasChildren ? ' org-leaf' : '' }}"{% if hasChildren or hasProjects %} open{% endif %}>
            <summary>
                <span class="org-name">{{ node.name }}</span>
                <span class="org-abbr">{{ node.orgCode }}</span>
                <a href="{{ node.projectListUrl }}"
                   class="org-count-link{{ node.directProjectCount == 0 ? ' zero' : '' }}"
                   title="查看该组织项目列表"
                   onclick="event.stopPropagation()">
                    {{ node.directProjectCount }} 项目
                </a>
                {% if node.totalProjectCount != node.directProjectCount %}
                    <span class="org-total-badge">合计 {{ node.totalProjectCount }}</span>
                {% endif %}
            </summary>

            {% if hasProjects %}
                <details class="org-project-details">
                    <summary>{{ node.directProjectCount }} 个直属项目</summary>
                    <ul class="org-project-list">
                        {% for project in node.projects %}
                            <li class="org-project-row">
                                <a href="{{ project.detailUrl }}" class="bg-info-subtle">
                                    <div class="d-flex align-items-center">
                                        <div class="org-project-row-name me-3">{{ project.name }}</div>
                                        {#
                                        <div class="org-project-row-meta"> {{ project.projectNumber }} </div>
                                        #}
                                        <div class="org-project-row-meta"> {{ project.leader }} </div>
                                    </div>
                                    <span class="badge bg-light text-dark">{{ project.statusLabel }}</span>
                                </a>
                            </li>
                        {% endfor %}
                    </ul>
                </details>
            {% endif %}

            {% if hasChildren %}
                <ul class="org-children">
                    {% for child in node.children %}
                        {{ _self.render_node(child) }}
                    {% endfor %}
                </ul>
            {% endif %}
        </details>
    </li>
{% endmacro %}

{% block content %}
<div class="container-fluid mt-3">
    {% if tree is empty %}
        <div class="text-center text-muted py-5">
            <i class="fa fa-sitemap fa-3x mb-3 d-block opacity-25"></i>
            <p class="mb-0">暂无可查看的组织机构</p>
        </div>
    {% else %}
        <div class="org-tree-toolbar">
            <button type="button" id="toggle-all-projects" class="btn btn-sm btn-outline-secondary">
                展开全部项目
            </button>
        </div>
        <ul class="org-tree-root">
            {% for node in tree %}
                {{ _self.render_node(node) }}
            {% endfor %}
        </ul>
    {% endif %}
</div>
{% endblock %}
