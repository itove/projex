{% if project.isOverdue() %}
    <div class="alert alert-danger project-overdue-alert mb-4" role="alert">
        <div class="d-flex align-items-start gap-3">
            <i class="fa fa-exclamation-triangle project-overdue-alert__icon" aria-hidden="true"></i>
            <div>
                <div class="project-overdue-alert__title">项目已逾期</div>
                <div class="project-overdue-alert__detail">
                    计划结束日期为 <strong>{{ project.plannedEndDate|date('Y年m月d日') }}</strong>，
                    已逾期 <strong>{{ project.overdueDays }} 天</strong>，请尽快推进项目进度。
                </div>
            </div>
        </div>
    </div>
{% endif %}
