{% if progressReportSummary.isOverdue %}
    <div class="alert alert-danger project-overdue-alert mb-4" role="alert">
        <div class="d-flex align-items-start gap-3">
            <i class="fa fa-exclamation-triangle project-overdue-alert__icon" aria-hidden="true"></i>
            <div>
                <div class="project-overdue-alert__title">本期进度报告逾期未填报</div>
                <div class="project-overdue-alert__detail">
                    本期截止日期为 <strong>{{ progressReportSummary.period.due|date('Y年m月d日') }}</strong>，
                    请尽快填报本期项目进度。
                </div>
            </div>
            <a href="{{ progressReportSummary.newUrl }}" class="btn btn-sm btn-danger ms-auto align-self-center">
                <i class="fa fa-plus"></i> 立即填报
            </a>
        </div>
    </div>
{% endif %}
