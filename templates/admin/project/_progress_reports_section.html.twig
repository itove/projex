{# @var progressReportSummary array #}
<div class="card mb-4" id="project-progress-reports">
    <div class="card-header d-flex justify-content-between align-items-center">
        <div>
            <i class="fas fa-chart-line"></i> 进度报告
        </div>
        <div class="d-flex gap-2">
            <a href="{{ progressReportSummary.newUrl }}" class="btn btn-sm btn-primary px-2">
                <i class="fas fa-plus"></i> 填报本期进度
            </a>
            <a href="{{ progressReportSummary.listUrl }}" class="btn btn-sm btn-outline-secondary">
                查看全部
            </a>
        </div>
    </div>
    <div class="card-body">
        {% if progressReportSummary.reports|length > 0 %}
            <div class="table-responsive">
                <table class="table table-sm table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>本期</th>
                            <th>完成百分比</th>
                            <th>进度状态</th>
                            <th>本月进度</th>
                            <th>下月计划</th>
                            <th>存在的困难和问题</th>
                            <th>填报人</th>
                            <th>填报时间</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for report in progressReportSummary.reports %}
                            <tr>
                                <td>
                                    <a href="{{ ea_url()
                                        .unsetAll()
                                        .setController('App\\Controller\\Admin\\ProjectProgressReportCrudController')
                                        .setAction('detail')
                                        .setEntityId(report.id) }}">
                                        {{ report.periodStartDate|date('Y-m-d') }} ~ {{ report.periodEndDate|date('Y-m-d') }}
                                    </a>
                                </td>
                                <td>{{ report.progressPercentage }}%</td>
                                <td>
                                    <span class="badge
                                        {% if report.statusTag.value == 'normal' %}bg-success
                                        {% elseif report.statusTag.value == 'at_risk' %}bg-warning text-dark
                                        {% else %}bg-danger{% endif %}">
                                        {{ report.statusTag.label }}
                                    </span>
                                </td>
                                <td>
                                    {{ report.currentProgressSummary|length > 30 ? report.currentProgressSummary|slice(0, 30) ~ '…' : report.currentProgressSummary }}
                                </td>
                                <td>
                                    {% if report.nextPeriodPlan %}
                                        {{ report.nextPeriodPlan|length > 30 ? report.nextPeriodPlan|slice(0, 30) ~ '…' : report.nextPeriodPlan }}
                                    {% else %}
                                        —
                                    {% endif %}
                                </td>
                                <td>
                                    {% if report.issues %}
                                        {{ report.issues|length > 30 ? report.issues|slice(0, 30) ~ '…' : report.issues }}
                                    {% else %}
                                        —
                                    {% endif %}
                                </td>
                                <td>{{ report.reportedBy ? report.reportedBy.name ?? report.reportedBy.username : '—' }}</td>
                                <td>{{ report.createdAt|date('Y-m-d H:i') }}</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        {% else %}
            <p class="text-muted text-center mb-0">暂无进度报告，点击「填报本期进度」添加。</p>
        {% endif %}
    </div>
</div>
