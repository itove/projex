{# @var taskSummary array #}
<div class="card mb-4" id="project-tasks">
    <div class="card-header d-flex justify-content-between align-items-center">
        <div>
            <i class="fas fa-tasks"></i> 项目任务
        </div>
        <div class="d-flex gap-2">
            <a href="{{ taskSummary.newUrl }}" class="btn btn-sm btn-primary px-2">
                <i class="fas fa-plus"></i> 新建任务
            </a>
            <a href="{{ taskSummary.listUrl }}" class="btn btn-sm btn-outline-secondary">
                查看全部
            </a>
        </div>
    </div>
    <div class="card-body">
        {#
        <div class="row text-center mb-3">
            <div class="col-md-6 mb-2 mb-md-0">
                <div class="summary-item">
                    <i class="fas fa-clipboard-list text-primary fa-2x mb-2"></i>
                    <h3 class="mb-0">{{ taskSummary.openCount }}</h3>
                    <small class="text-muted">进行中任务</small>
                </div>
            </div>
            <div class="col-md-6">
                <div class="summary-item">
                    <i class="fas fa-exclamation-circle text-danger fa-2x mb-2"></i>
                    <h3 class="mb-0">{{ taskSummary.overdueCount }}</h3>
                    <small class="text-muted">逾期任务</small>
                </div>
            </div>
        </div>
        #}

        {% if taskSummary.tasks|length > 0 %}
            <div class="table-responsive">
                <table class="table table-sm table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>任务名称</th>
                            <th>责任单位</th>
                            <th>配合单位</th>
                            <th>开始时间</th>
                            <th>结束时间</th>
                            <th>天数</th>
                            <th>当前进度</th>
                            <th>状态</th>
                            <th>负责人</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for task in taskSummary.tasks %}
                            <tr>
                                <td>
                                    <a href="{{ ea_url()
                                        .setController('App\\Controller\\Admin\\ProjectTaskCrudController')
                                        .setAction('detail')
                                        .setEntityId(task.id) }}">
                                        {{ task.title }}
                                    </a>
                                </td>
                                <td>{{ task.responsibleUnit ?? '—' }}</td>
                                <td>{{ task.cooperatingUnit ?? '—' }}</td>
                                <td>{{ task.startDate ? task.startDate|date('Y-m-d') : '—' }}</td>
                                <td>{{ task.endDate ? task.endDate|date('Y-m-d') : '—' }}</td>
                                <td>{{ task.durationDays ?? '—' }}</td>
                                <td>
                                    {% if task.progressText %}
                                        {{ task.progressText|length > 30 ? task.progressText|slice(0, 30) ~ '…' : task.progressText }}
                                    {% else %}
                                        —
                                    {% endif %}
                                </td>
                                <td>
                                    <span class="badge
                                        {% if task.status.value == 'done' %}bg-success
                                        {% elseif task.status.value == 'in_progress' %}bg-warning text-dark
                                        {% elseif task.status.value == 'cancelled' %}bg-danger
                                        {% else %}bg-secondary{% endif %}">
                                        {{ task.status.label }}
                                    </span>
                                    {% if task.isOverdue %}
                                        <span class="badge bg-danger ms-1">逾期</span>
                                    {% endif %}
                                </td>
                                <td>{{ task.assignee ? task.assignee.name ?? task.assignee.username : '—' }}</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        {% else %}
            <p class="text-muted text-center mb-0">暂无任务，点击「新建任务」添加。</p>
        {% endif %}
    </div>
</div>
