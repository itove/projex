{% extends '@EasyAdmin/page/content.html.twig' %}

{% block head_javascript %}
    {{ parent() }}
    {{ importmap('app') }}
{% endblock %}

{% block head_stylesheets %}
{{ parent() }}
<style>
    .badge{
      padding: 2px 6px;
    }
    .content-top{
      margin-bottom: 20px;
    }
    .project-card {
        transition: transform 0.2s, box-shadow 0.2s;
    }
    .project-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 4px 20px rgba(0,0,0,0.15) !important;
    }
    .badge-secondary {
        background-color: #6c757d;
    }
    .badge-info {
        background-color: #0dcaf0;
    }
    .badge-success {
        background-color: #198754;
    }
    .badge-warning {
        background-color: #ffc107;
        color: #000;
    }
    .badge-danger {
        background-color: #dc3545;
    }
    .badge-primary {
        background-color: #0d6efd;
    }
    .stat-card {
        border-radius: 0.5rem;
        border: none;
        color: white;
    }
    .stat-card .fa-3x {
        opacity: 0.5;
    }
    .stage-icon {
        font-size: 2rem;
    }
    a.stat-card-link {
        display: block;
        text-decoration: none;
        color: inherit;
        transition: transform 0.2s, box-shadow 0.2s;
    }
    a.stat-card-link:hover {
        transform: translateY(-3px);
        box-shadow: 0 4px 16px rgba(0, 0, 0, 0.15);
        color: inherit;
    }
    a.stage-distribution-link {
        display: block;
        text-decoration: none;
        color: inherit;
        border-radius: 0.375rem;
        padding: 0.5rem;
        transition: background 0.15s;
    }
    a.stage-distribution-link:hover {
        background: #f8f9fa;
        color: inherit;
    }
</style>
{% endblock %}

{% block page_title %}项目展示主页{% endblock %}

{% block content %}
<div class="container-fluid">

    {# Project Title Image Slideshow #}
    {% if slideProjects|length > 0 %}
    <div id="projectSlideshow" class="carousel slide mb-4 rounded overflow-hidden shadow" data-bs-ride="carousel">
        <div class="carousel-indicators">
            {% for project in slideProjects %}
            <button type="button" data-bs-target="#projectSlideshow" data-bs-slide-to="{{ loop.index0 }}"
                    {% if loop.first %}class="active" aria-current="true"{% endif %}
                    aria-label="{{ project.projectName }}"></button>
            {% endfor %}
        </div>
        <div class="carousel-inner">
            {% for project in slideProjects %}
            <div class="carousel-item {% if loop.first %}active{% endif %}">
                <a href="{{ path('admin_project_detail', { entityId: project.id }) }}">
                    <img src="/uploads/title-images/{{ project.titleImageName }}"
                         class="d-block w-100"
                         style="max-height: 420px; object-fit: cover;"
                         alt="{{ project.projectName }}">
                </a>
                <div class="carousel-caption d-none d-md-block" style="background: rgba(0,0,0,0.45); border-radius: 0.5rem; padding: 0.75rem 1.25rem;">
                    <h5 class="mb-1">
                        <a href="{{ path('admin_project_detail', { entityId: project.id }) }}" class="text-white text-decoration-none">
                            {{ project.projectName }}
                        </a>
                    </h5>
                    <p class="mb-0 small">
                        <i class="fas fa-map-marker-alt"></i> {{ project.projectLocation }}
                    </p>
                </div>
            </div>
            {% endfor %}
        </div>
        <button class="carousel-control-prev" type="button" data-bs-target="#projectSlideshow" data-bs-slide="prev">
            <span class="carousel-control-prev-icon" aria-hidden="true"></span>
            <span class="visually-hidden">上一张</span>
        </button>
        <button class="carousel-control-next" type="button" data-bs-target="#projectSlideshow" data-bs-slide="next">
            <span class="carousel-control-next-icon" aria-hidden="true"></span>
            <span class="visually-hidden">下一张</span>
        </button>
    </div>
    {% endif %}

    {# 4.3.2.3 Data Overview Widgets #}
    <div class="row mb-4">
        <div class="col-md-3 mb-3">
            <a href="{{ statisticsLinks.total }}" class="stat-card-link">
                <div class="card stat-card bg-primary text-white">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="card-subtitle mb-2 text-white">项目总数</h6>
                                <h2 class="card-title mb-0">{{ statistics.total }}</h2>
                            </div>
                            <div>
                                <i class="fas fa-project-diagram fa-3x"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </a>
        </div>

        <div class="col-md-3 mb-3">
            <a href="{{ statisticsLinks.in_progress }}" class="stat-card-link">
                <div class="card stat-card bg-success text-white">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="card-subtitle mb-2 text-white">进行中</h6>
                                <h2 class="card-title mb-0">{{ statistics.byStatus.in_progress }}</h2>
                            </div>
                            <div>
                                <i class="fas fa-spinner fa-3x"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </a>
        </div>

        <div class="col-md-3 mb-3">
            <a href="{{ statisticsLinks.closed }}" class="stat-card-link">
                <div class="card stat-card bg-info text-white">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="card-subtitle mb-2 text-white">已闭环</h6>
                                <h2 class="card-title mb-0">{{ statistics.closed }}</h2>
                            </div>
                            <div>
                                <i class="fas fa-check-circle fa-3x"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </a>
        </div>

        <div class="col-md-3 mb-3">
            <a href="{{ statisticsLinks.cancelled }}" class="stat-card-link">
                <div class="card stat-card bg-danger text-white">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="card-subtitle mb-2 text-white">已终止</h6>
                                <h2 class="card-title mb-0">{{ statistics.byStatus.cancelled }}</h2>
                            </div>
                            <div>
                                <i class="fas fa-times-circle fa-3x"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </a>
        </div>
    </div>

    {# Lifecycle Stage Distribution #}
    <div class="row mb-4">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <div class="mb-0">各流程阶段项目分布</div>
                </div>
                <div class="card-body">
                    <div class="row text-center">
                        <div class="col">
                            <a href="{{ statisticsLinks.stages.preliminary }}" class="stage-distribution-link">
                                <div class="mb-2">
                                    <i class="fas fa-file-alt stage-icon text-primary"></i>
                                </div>
                                <h6>前期决策</h6>
                                <p class="h4 text-primary mb-0">{{ statistics.byStage.preliminary }}</p>
                            </a>
                        </div>
                        <div class="col">
                            <a href="{{ statisticsLinks.stages.approval }}" class="stage-distribution-link">
                                <div class="mb-2">
                                    <i class="fas fa-check-square stage-icon text-success"></i>
                                </div>
                                <h6>立项</h6>
                                <p class="h4 text-success mb-0">{{ statistics.byStage.approval }}</p>
                            </a>
                        </div>
                        <div class="col">
                            <a href="{{ statisticsLinks.stages.planning }}" class="stage-distribution-link">
                                <div class="mb-2">
                                    <i class="fas fa-pencil-ruler stage-icon text-info"></i>
                                </div>
                                <h6>规划设计</h6>
                                <p class="h4 text-info mb-0">{{ statistics.byStage.planning }}</p>
                            </a>
                        </div>
                        <div class="col">
                            <a href="{{ statisticsLinks.stages.preparation }}" class="stage-distribution-link">
                                <div class="mb-2">
                                    <i class="fas fa-tools stage-icon text-warning"></i>
                                </div>
                                <h6>施工准备</h6>
                                <p class="h4 text-warning mb-0">{{ statistics.byStage.preparation }}</p>
                            </a>
                        </div>
                        <div class="col">
                            <a href="{{ statisticsLinks.stages.implementation }}" class="stage-distribution-link">
                                <div class="mb-2">
                                    <i class="fas fa-hard-hat stage-icon text-danger"></i>
                                </div>
                                <h6>施工实施</h6>
                                <p class="h4 text-danger mb-0">{{ statistics.byStage.implementation }}</p>
                            </a>
                        </div>
                        <div class="col">
                            <a href="{{ statisticsLinks.stages.acceptance }}" class="stage-distribution-link">
                                <div class="mb-2">
                                    <i class="fas fa-clipboard-check stage-icon text-secondary"></i>
                                </div>
                                <h6>竣工验收</h6>
                                <p class="h4 text-secondary mb-0">{{ statistics.byStage.acceptance }}</p>
                            </a>
                        </div>
                        <div class="col">
                            <a href="{{ statisticsLinks.stages.settlement }}" class="stage-distribution-link">
                                <div class="mb-2">
                                    <i class="fas fa-calculator stage-icon text-dark"></i>
                                </div>
                                <h6>竣工结算</h6>
                                <p class="h4 text-dark mb-0">{{ statistics.byStage.settlement }}</p>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    {# 4.3.2.2 Filter and Search Interface #}
    {% include 'dashboard/_filters.html.twig' %}

    {# Quick Action: New Project Registration (4.3.1 - Point 6) #}
    <div class="row my-3">
        <div class="col-12">
            <a href="{{ path('admin_project_new') }}" class="btn btn-primary btn-lg">
                <i class="fas fa-plus-circle"></i> 新增项目登记
            </a>
        </div>
    </div>

    {# 4.3.2.1 Project Cards Display #}
    <div class="row">
        <div class="col-12">
            {% if projectCards|length > 0 %}
                <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
                    {% for card in projectCards %}
                        {% include 'dashboard/_project_card.html.twig' with {'card': card} %}
                    {% endfor %}
                </div>
            {% else %}
                <div class="alert alert-info" role="alert">
                    <i class="fas fa-info-circle"></i> 暂无项目数据
                </div>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}
